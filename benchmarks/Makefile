# Makefile to compile and run run_benchmarks.c with libnuma

# Compiler
CC = gcc

# Compiler flags
CFLAGS = -O2 -Wall -pthread

# Linker flags
LDFLAGS = -lpthread -lnuma

.PHONY:
pascal_comp:
	echo "\n笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武"
	echo "Compiling Pascal Benchmark"
	echo "笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武"
	$(CC) $(CFLAGS) -o pascal_bench pascal_bench.c $(LDFLAGS)

.PHONY:
